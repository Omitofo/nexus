# ================================================================
# NEXUS — Environment Variables
# ================================================================
# Setup: https://supabase.com/dashboard → New project → Settings → API
#
# Copy this file:
#   cp .env.example apps/web/.env.local   (frontend)
#   cp .env.example apps/api/.env         (backend)
#
# NEVER commit files with real values. .env* is in .gitignore.
# ================================================================

# ── FRONTEND (apps/web/.env.local) ──────────────────────────────────
# Both values are safe to expose in browser code.
# Row Level Security at the DB level controls access.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# URL of the Fastify API (change for production)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── BACKEND (apps/api/.env) ─────────────────────────────────────────
# These MUST stay server-side only. Never expose in frontend code.

# Same project URL as above
SUPABASE_URL=https://your-project-ref.supabase.co

# service_role key — bypasses RLS. Keep this secret.
# Find it: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT secret for verifying tokens issued by Supabase Auth
# Find it: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Server config
PORT=3001
NODE_ENV=development

# Your frontend URL — only this origin is allowed to call the API
CORS_ORIGIN=http://localhost:3000

# External price feeds — leave blank until Phase 9
PRICE_FEED_API_KEY=
PRICE_FEED_BASE_URL=
